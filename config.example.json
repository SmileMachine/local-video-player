{
  "cacheName": "video-info",
  "usePathIds": true,
  "getVideoInfo": true,
  "audioTranscode": {
    "enabled": true,
    "cacheDir": "cache/audio",
    "codec": "aac",
    "maxBitrate": "384k",
    "maxChannels": 2
  },
  "videoPaths": [
    {
      "name": "Videos",
      "path": "~/Movies"
    },
    {
      "name": "Downloads",
      "path": "~/Downloads"
    }
  ]
}
